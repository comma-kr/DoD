# ============================================================
# 입지990 .gitignore
# ============================================================

# Dependencies
**/node_modules/
**/.pnp
**/.pnp.js

# Next.js build / dev artifacts
**/.next/
**/out/
**/build/
**/dist/

# 환경변수 (절대 커밋 금지)
.env
.env.local
.env*.local
**/.env
**/.env.local
**/.env*.local

# 로그 / 진단
*.log
**/.next/dev/logs/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Coverage / test
coverage/
*.lcov

# 캐시
.cache/
.eslintcache
.stylelintcache
**/.turbo/

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# 임시 파일
*.tmp
*.bak

# Claude Code 설정 (로컬)
.claude/settings.local.json
