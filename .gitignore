# ============================================================
# 입지990 .gitignore
# ============================================================

# Dependencies
**/node_modules/
**/.pnp
**/.pnp.js

# Next.js build / dev artifacts
**/.next/
**/out/
**/build/
**/dist/

# 환경변수 (절대 커밋 금지)
.env
.env.local
.env*.local
**/.env
**/.env.local
**/.env*.local

# 로그 / 진단
*.log
**/.next/dev/logs/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Coverage / test
coverage/
*.lcov

# 캐시
.cache/
.eslintcache
.stylelintcache
**/.turbo/

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# 임시 파일
*.tmp
*.bak

# Claude Code 설정 (로컬)
.claude/settings.local.json

# SBA 공식 상권 데이터셋 — 원본은 ignore (대용량·재배포 제한),
# 단 빌드 산출물 zones.geojson(9MB)만 예외로 git 포함 (Vercel 빌드에 필요).
# 라이선스: 공공누리 제3유형 (출처 표시 — NeighborhoodMap 하단 캡션에 SBA 표기).
app/data/seoul-commercial-zones/*.shp
app/data/seoul-commercial-zones/*.dbf
app/data/seoul-commercial-zones/*.shx
app/data/seoul-commercial-zones/*.prj
app/data/seoul-commercial-zones/*.cpg
app/data/seoul-commercial-zones/*.json
app/data/seoul-commercial-zones/*.geojson
!app/data/seoul-commercial-zones/zones.geojson
app/data/seoul-commercial-zones/*.csv
